{
  "name": "@mammals-at-work/yacs",
  "version": "0.8.7",
  "description": "Interactive CLI installer for Y.A.C.S. (Yet Another Claude Skills)",
  "type": "module",
  "bin": {
    "yacs": "./install.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mammals-at-work/YACS.git",
    "directory": "cli"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "start": "node install.js",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch"
  },
  "keywords": [
    "yacs",
    "skills",
    "installer",
    "cli",
    "claude",
    "codex"
  ],
  "author": "Carlos L x Mammals at Work",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "inquirer": "13.3.0"
  },
  "devDependencies": {
    "jest": "29.5.0"
  },
  "overrides": {
    "glob": "13.0.6"
  }
}
